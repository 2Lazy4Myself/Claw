# Claw — Environment Variables
# Copy this file to .env (gitignored) and fill in your values.
# These are secrets. Never commit them to git.

# Anthropic API key — from https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# Telegram bot token — from @BotFather on Telegram
# This should be Claw's dedicated bot, not shared with openclaw or the PM engine.
TELEGRAM_BOT_TOKEN=...

# Todoist API token — from https://app.todoist.com/app/settings/integrations/developer
TODOIST_API_TOKEN=...
