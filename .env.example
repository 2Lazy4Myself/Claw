# Claw — Environment Variables
# Copy this file to .env (gitignored) and fill in your values.
# These are secrets. Never commit them to git.

# LiteLLM proxy API key. All AI calls route through the LiteLLM container
# (OpenAI-compatible) rather than calling Anthropic directly — see ADR-009.
# The proxy URL is set in config.yaml (litellm.base_url); override here with
# LITELLM_BASE_URL if needed.
LITELLM_API_KEY=sk-...
# LITELLM_BASE_URL=http://192.168.1.100:4000

# Telegram bot token and your Telegram user ID.
# Shared with the parent todoist-telegram project on Unraid.
TELEGRAM_BOT_TOKEN=...
TELEGRAM_CHAT_ID=...

# Todoist API token — from https://app.todoist.com/app/settings/integrations/developer
TODOIST_API_TOKEN=...
